# SMTP Proxy Configuration
listen_host: "0.0.0.0"
listen_port: 2525

# Health check endpoint
health_port: {{ shinobi_smtp_proxy_health_port }}

# Shinobi SMTP Server
forward_host: "shinobi-smtp2.{{ site_fqdn }}"
forward_port: 2525

# Logging
log_level: "INFO"

# Subject line cleaning
clean_subjects: true
fallback_subject: "Motion Detected"

# Subject filtering - drop emails containing these keywords
filter_keywords:
  - "Intensity Change Stop"
  - "Intensity Change"
  - "Motion Detection Stop"

# Debug: log MIME structure of every email
debug_mime: true

# AI Image Detection (reduces false positives)
# Uses local YOLOv8n model to detect people, vehicles, and animals
ai_detection_enabled: true
confidence_threshold: 0.25  # Detection confidence (0.0-1.0, lower = more sensitive)

# Baseline detection - polls cameras to filter out stationary objects
baseline_interval: {{ shinobi_smtp_proxy_baseline_interval }}  # seconds between baseline YOLO runs
position_tolerance: {{ shinobi_smtp_proxy_position_tolerance }}  # 0-1, how close two detections must be to match

# Rolling snapshot buffer - captures frames continuously for pre-event analysis
snapshot_interval: {{ shinobi_smtp_proxy_snapshot_interval }}  # seconds between snapshots per camera (http strategy only)
buffer_seconds: {{ shinobi_smtp_proxy_buffer_seconds }}  # how many seconds of snapshots to keep

# Camera frame strategy: 'rtsp' (persistent MJPEG sub-stream) or 'http' (polling snapshots)
camera_strategy: rtsp

# Discord notifications (bot token + channel ID come from env vars / Secret)
discord_cooldown: {{ shinobi_smtp_proxy_discord_cooldown }}  # seconds between alerts per camera

# Camera IPs keyed by sender email prefix (e.g. camnorthtoeast -> 192.168.x.x)
# Credentials come from CAMERA_USERNAME / CAMERA_PASSWORD env vars (Secret)
cameras:
{% for cam_id, cam_ip in shinobi_smtp_proxy_cameras.items() %}
  {{ cam_id }}: "{{ cam_ip }}"
{% endfor %}
